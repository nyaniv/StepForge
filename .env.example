# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# HuggingFace token (required for gated Llama model + Text2CAD dataset download)
HUGGINGFACE_TOKEN=hf_...

# RunPod Network Volume mount point (default for RunPod)
VOLUME=/runpod-volume

# Path where this repo is cloned on the pod
REPO=/workspace/StepForge
